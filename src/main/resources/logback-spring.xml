<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
      Two appenders:
        - CONSOLE: human-readable, used by default and in the `local` profile.
        - JSON:    structured one-line-per-event JSON, used in production-shaped
                   environments. Logstash encoder serializes MDC, so the
                   correlationId stamped by CorrelationIdFilter shows up
                   automatically on every log line within a request.
    -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId:-}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdc>true</includeMdc>
            <customFields>{"application":"ledger-service"}</customFields>
        </encoder>
    </appender>

    <springProfile name="local | default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!local &amp; !default">
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

</configuration>
